font pango:DejaVu Sans Mono 12.000000
floating_modifier Mod4
default_border pixel 2
default_floating_border normal 2
hide_edge_borders none
focus_wrapping no
focus_follows_mouse yes
focus_on_window_activation smart
mouse_warping output
workspace_layout default
workspace_auto_back_and_forth no
client.focused #272D38 #272D38 #F3F4F5 #272D38 #272D38
client.focused_inactive #131721 #131721 #E6E1CF #131721 #131721
client.unfocused #0F1419 #0F1419 #BFBDB6 #0F1419 #0F1419
client.urgent #F07178 #F07178 #F3F4F5 #F07178 #F07178
client.placeholder #0F1419 #0F1419 #BFBDB6 #0F1419 #0F1419
client.background #F3F4F5

exec systemctl --user set-environment QT_QPA_PLATFORMTHEME=kde

gaps inner 8
gaps outer 4

bindsym --locked XF86AudioLowerVolume exec wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_SOURCE@ toggle
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_SINK@ toggle
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioPrev exec playerctl previous
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1.0
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym Ctrl+Mod1+Print exec grim -g "$(swaymsg -t get_tree | jq -j '.. | select(.type?) | select(.focused).rect | "\(.x),\(.y) \(.width)x\(.height)"')"
bindsym Ctrl+Print exec grim
bindsym Ctrl+Shift+Print exec grim -g "$(slurp)"
bindsym Mod1+Print exec grim -g "$(swaymsg -t get_tree | jq -j '.. | select(.type?) | select(.focused).rect | "\(.x),\(.y) \(.width)x\(.height)"')" - | wl-copy
bindsym Mod4+0 workspace number 10
bindsym Mod4+1 workspace number 1
bindsym Mod4+2 workspace number 2
bindsym Mod4+3 workspace number 3
bindsym Mod4+4 workspace number 4
bindsym Mod4+5 workspace number 5
bindsym Mod4+6 workspace number 6
bindsym Mod4+7 workspace number 7
bindsym Mod4+8 workspace number 8
bindsym Mod4+9 workspace number 9
bindsym Mod4+Down focus down
bindsym Mod4+Left focus left
bindsym Mod4+Return exec alacritty
bindsym Mod4+Right focus right
bindsym Mod4+Shift+0 move container to workspace number 10
bindsym Mod4+Shift+1 move container to workspace number 1
bindsym Mod4+Shift+2 move container to workspace number 2
bindsym Mod4+Shift+3 move container to workspace number 3
bindsym Mod4+Shift+4 move container to workspace number 4
bindsym Mod4+Shift+5 move container to workspace number 5
bindsym Mod4+Shift+6 move container to workspace number 6
bindsym Mod4+Shift+7 move container to workspace number 7
bindsym Mod4+Shift+8 move container to workspace number 8
bindsym Mod4+Shift+9 move container to workspace number 9
bindsym Mod4+Shift+Down move down
bindsym Mod4+Shift+Left move left
bindsym Mod4+Shift+Right move right
bindsym Mod4+Shift+Up move up
bindsym Mod4+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -b 'Yes, exit sway' 'swaymsg exit'
bindsym Mod4+Shift+f floating toggle
bindsym Mod4+Shift+h move left
bindsym Mod4+Shift+j move down
bindsym Mod4+Shift+k move up
bindsym Mod4+Shift+l move right
bindsym Mod4+Shift+minus move scratchpad
bindsym Mod4+Shift+p 1password --show
bindsym Mod4+Shift+q kill
bindsym Mod4+Shift+r reload
bindsym Mod4+Shift+s exec systemctl suspend
bindsym Mod4+d exec fuzzel
bindsym Mod4+Up focus up
bindsym Mod4+a focus parent
bindsym Mod4+f fullscreen toggle
bindsym Mod4+h focus left
bindsym Mod4+j focus down
bindsym Mod4+k focus up
bindsym Mod4+l focus right
bindsym Mod4+minus scratchpad show
bindsym Mod4+p 1password --quick-accessd
bindsym Mod4+r mode resize
bindsym Mod4+s exec swaylock -f
bindsym Print exec grim - | wl-copy
bindsym Shift+Print exec grim -g "$(slurp)" - | wl-copy

input "type:keyboard" {
  xkb_numlock enabled
}

input "type:pointer" {
  scroll_factor 2
}


output "DP-1" {
  mode 3440x1440@144Hz
  position 1920 0
  bg ~/.config/sway/View_of_Vent_in_the_Ventertal.jpg fill #0F1419
}

output "DP-2" {
  mode 1920x1080@144Hz
  position 0 0
  bg ~/.config/sway/View_of_Vent_in_the_Ventertal.jpg fill #0F1419
}

mode "resize" {
  bindsym Down resize grow height 10 px
  bindsym Escape mode default
  bindsym Left resize shrink width 10 px
  bindsym Return mode default
  bindsym Right resize grow width 10 px
  bindsym Up resize shrink height 10 px
  bindsym h resize shrink width 10 px
  bindsym j resize grow height 10 px
  bindsym k resize shrink height 10 px
  bindsym l resize grow width 10 px
}

bar {
  font pango:monospace 8.000000
  swaybar_command waybar
}

for_window [app_id="org.kde.dolphin"] opacity 0.96
for_window [app_id="org.pulseaudio.pavucontrol"] floating enable
for_window [app_id="nm-openconnect-auth-dialog"] floating enable
for_window [app_id="lxqt-openssh-askpass"] floating enable
exec systemctl --user set-environment XDG_CURRENT_DESKTOP=sway



exec systemctl --user import-environment DISPLAY SWAYSOCK WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

exec hash dbus-update-activation-environment 2>/dev/null && dbus-update-activation-environment --systemd DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway WAYLAND_DISPLAY

exec systemctl --user reset-failed && systemctl --user start sway-session.target && swaymsg -mt subscribe '[]' || true && systemctl --user stop sway-session.target

exec swayidle -w


exec /usr/lib/hyprpolkitagent/hyprpolkitagent

